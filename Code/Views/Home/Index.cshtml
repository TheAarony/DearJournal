@{
    ViewData["Title"] = "Home Page";
}

@model List<Code.Models.JournalDb>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-3">
            <div class="justify-content-center text-center">
                <h4>Journals</h4>
                <p> 0 </p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="justify-content-center text-center">
                <h4>Streak</h4>
                <p> 0 </p>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-lg-12">
            <div>
                <h4> Journals </h4>
                @{
                    foreach(var journal in Model)
                    {
                        <h3> @journal.Title</h3>
                        <p>@journal.Content</p>
                    }
                    } 
                
            </div>
        </div>
    </div>
</div>