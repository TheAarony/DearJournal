@{
    ViewData["Title"] = "Home Page";
}

@model List<Code.Models.JournalDb>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-3 m-3 p-3">
            <div class="justify-content-center text-center border rounded-4 shadow p-3 ">
                <h4>Journals</h4>
                <h1> @ViewData["JournalCount"] </h1>
            </div>
        </div>
        <div class="col-md-3 m-3 p-3">
            <div class="justify-content-center text-center border rounded-4 shadow p-3">
                <h4>Streak</h4>
                <h1> 0 </h1>
            </div>
        </div>
    </div>
    <div class="row pt-5">
        <div class="col-lg-12 border rounded-4 shadow">
            <div class="container m-3">
                <h3 class="border-bottom pb-2" > Journals </h3>
                @if(Model == null || !Model.Any())
                {
                    <p class="text-muted justify-content-center text-center" style="font-size: 30px; text-color: rgb(184, 184, 184);">No Journals Found</p>
                }
                else
                {
                    foreach(var journal in Model)
                    {
                        <h4> @journal.Title</h4>
                        <p>@journal.Content</p>
                        <div class="">
                            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#editModal-@journal.Id">Edit</button>
                            <button class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal-@journal.Id">Delete</button>
                        </div>
                        <div class="modal fade" id="editModal-@journal.Id" tab-index="-1" aria-labelledby="editModalLabel" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <form asp-action="EditJournal" asp-controller="Home">
                                        <input hidden class="form-control" name="Id" type="number" value="@journal.Id" />
                                        <div class="modal-header">
                                            <input type="text" name="Title" class="form-control" placeholder="@journal.Title" value="@journal.Title"/>
                                            <button type="button" class="btn-close" data-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body">
                                            <textarea class="form-control" rows="5" name="Content">@journal.Content</textarea>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                            <button type="submit" class="btn btn-primary">Save changes</button>
                                        </div>
                                    </form>
                                </div>
                            </div>`
                        </div>

                        <div class="modal fade" id="deleteModal-@journal.Id" tab-index="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <form asp-action="DeleteJournal" asp-controller="Home">
                                        <input hidden class="form-control" name="Id" type="number" value="@journal.Id" />
                                        <div class="modal-header">
                                            <p> Confirm deletion</p>
                                        </div>
                                        <div class="modal-body">
                                            <p>Are you sure you want to delete this journal?</p>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                            <button type="submit" class="btn btn-primary">Confirm</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                } 
            </div>
        </div>
    </div>
</div>